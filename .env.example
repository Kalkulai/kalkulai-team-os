GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
HUBSPOT_ACCESS_TOKEN=
NOTION_TOKEN=
NOTION_TRANSCRIPTS_DB_ID=
TELEGRAM_BOT_TOKEN=
DASHBOARD_API_SECRET=
NEXT_PUBLIC_DASHBOARD_API_SECRET=
# Team-Login (Passwort-Gate + HMAC-Cookie, siehe lib/auth-cookie.ts)
TEAM_OS_ACCESS_PASSWORD=
TEAM_OS_AUTH_SECRET=
GITHUB_WEBHOOK_SECRET=
CRON_SECRET=
# Finance / CFO-Kai Sheets-Sync (siehe lib/google-sheets.ts, lib/finance-sync.ts)
# Aktives Szenario, das Dashboard + Sync verwenden ('current' | 'exist').
ACTIVE_FINANCE_SCENARIO=current
# Telegram-Chat-ID für Sync-Fehler-Alarme (fail-safe).
FINANCE_ALERT_CHAT_ID=
# Google-Sheets-Auth, DREI Wege (einer reicht — erster konfigurierter gewinnt):
#  A) OAuth2-Refresh-Token (EINFACHSTER) — greift als Google-User zu.
#     Eigener Web-OAuth-Client für Finance (entkoppelt vom Calendar-Desktop-Client);
#     Fallback auf GOOGLE_CLIENT_ID/SECRET, wenn die Finance-Vars leer sind.
GOOGLE_FINANCE_CLIENT_ID=
GOOGLE_FINANCE_CLIENT_SECRET=
GOOGLE_FINANCE_REFRESH_TOKEN=
#  B) Keyless via Workload Identity Federation (kein Key; Vercel-OIDC nötig):
GCP_PROJECT_NUMBER=
GCP_WORKLOAD_IDENTITY_POOL_ID=
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=
GCP_SERVICE_ACCOUNT_EMAIL=
#  C) Service-Account-JSON-Key (lokal/Fallback — gesamter Key-JSON als String):
GOOGLE_SERVICE_ACCOUNT_JSON=
# Agent-Runner (Agent Cockpit terminals, siehe agent-runner/server.mjs)
AGENT_RUNNER_TOKEN=
NEXT_PUBLIC_AGENT_RUNNER_TOKEN=
AGENT_RUNNER_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AGENT_RUNNER_ALLOW_LOCAL_DEV_ORIGINS=true
AGENT_RUNNER_ALLOWED_CWD_ROOTS=C:\Kalkulai
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
